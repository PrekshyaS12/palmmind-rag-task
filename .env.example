# --- Gemini (LLM + Embeddings) ---
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxx

# --- Pinecone ---
PINECONE_API_KEY=pcsk_xxxxxxxx
PINECONE_INDEX_NAME=palm-mind-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Database (SQLite for local/dev, swap to Postgres URL for prod) ---
DATABASE_URL=sqlite:///./app_data.db

# --- Redis (chat memory) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CHAT_MEMORY_TTL_SECONDS=86400
CHAT_MEMORY_MAX_TURNS=10

# --- App ---
APP_NAME=PalmMind RAG Service
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=768
CHAT_MODEL=gemini-2.5-flash